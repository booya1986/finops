# FinOps — .env הוא fallback בלבד. הדרך המועדפת (PLAN.md §1.1):
#   npm run secrets -- set <name>        ← אחסון ב-macOS Keychain
#
# אם בכל זאת משתמשים ב-.env:
#   cp .env.example .env && chmod 600 .env
# הקובץ .env לעולם לא נכנס ל-git (ראה .gitignore).
#
# האוטומציה כבויה כברירת מחדל (fail closed). להפעלה מפורשת בלבד:
# FINOPS_AUTOMATION_ENABLED=1
#
# Kill switch מיידי גם כשהמשתנה פעיל:
#   touch data/AUTOMATION_DISABLED
# אין לשים כאן ערכים אמיתיים.
