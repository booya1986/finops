{
  "name": "finops",
  "version": "0.1.0",
  "private": true,
  "description": "סוכן יועץ פיננסי אישי אוטונומי + לייב דשבורד — מקומי בלבד, קריאה בלבד",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "setup": "tsx src/setup/wizard.ts",
    "verify:clean": "node scripts/verify-clean.mjs",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "secrets": "tsx src/secrets/cli.ts",
    "secrets:import": "tsx src/secrets/import-server.ts",
    "ingest": "tsx src/ingest/run.ts",
    "ingest:selftest": "tsx src/ingest/selftest.ts",
    "reclassify": "tsx src/ingest/reclassify.ts",
    "brief": "tsx src/features/cli.ts",
    "brief:selftest": "tsx src/features/selftest.ts",
    "goals:selftest": "tsx src/goals/selftest.ts",
    "contract:check": "node scripts/contract-check.mjs",
    "advise": "tsx src/advisor/run.ts",
    "report": "tsx src/reports/generate.ts",
    "automation": "tsx src/automation/run.ts",
    "automation:selftest": "tsx src/automation/selftest.ts",
    "dashboard": "npm run dashboard:build && tsx src/dashboard/server.ts",
    "dashboard:build": "npm --prefix src/dashboard/web run build",
    "dashboard:legacy": "FINOPS_DASH_LEGACY=1 tsx src/dashboard/server.ts",
    "audit": "npm audit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.112.3",
    "@napi-rs/keyring": "1.3.0",
    "better-sqlite3": "12.11.1",
    "dotenv": "17.4.2",
    "israeli-bank-scrapers": "6.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  }
}
